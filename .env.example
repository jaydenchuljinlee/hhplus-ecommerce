# ============================================================
# hhplus-ecommerce 환경변수 템플릿
# 사용법: 이 파일을 .env 로 복사하고 실제 값으로 교체하세요.
#   cp .env.example .env
# 주의: .env 파일은 절대 Git에 커밋하지 마세요.
# ============================================================

# ── JWT ─────────────────────────────────────────────────────
# 운영 환경에서는 반드시 강력한 임의 문자열로 교체 (최소 32자 이상 권장)
# 생성 예시: openssl rand -base64 64
JWT_SECRET_KEY=replace-this-with-a-strong-random-secret-key-at-least-32-chars
